ENVIRONMENT=dev
LOG_LEVEL=INFO
LOG_FORMAT=text

# SQLite database (auto-created on startup)
DATABASE_URL=sqlite+aiosqlite:///./data/mission-control.db

# CORS: allow the frontend origin
CORS_ORIGINS=http://localhost:3000

# REQUIRED: must be reachable by gateway runtime
BASE_URL=http://localhost:8000

# Auth: local token (must be at least 50 characters)
AUTH_MODE=local
LOCAL_AUTH_TOKEN=

# Database auto-migration (creates tables on startup in dev)
DB_AUTO_MIGRATE=true

# Gateway compatibility
GATEWAY_MIN_VERSION=2026.02.9
