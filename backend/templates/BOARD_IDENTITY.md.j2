{% set is_lead = (is_board_lead | default(false) | string | lower) in ["true", "1", "yes"] %}
{% set role_lower = (identity_role | default("") | lower) %}
{% set role_display = (identity_role or "Board Lead") if is_lead else identity_role %}
{% set acp_flow = identity_dev_acp_flow | default("") %}
{% if not acp_flow %}
{% if "frontend" in role_lower %}
{% set acp_flow = "claude_then_codex_review" %}
{% elif "backend" in role_lower %}
{% set acp_flow = "codex_then_claude_review" %}
{% elif "devops" in role_lower or "infra" in role_lower %}
{% set acp_flow = "claude_with_optional_claude_review" %}
{% elif "architect" in role_lower %}
{% set acp_flow = "review_only" %}
{% endif %}
{% endif %}

